# Supply-chain hardening.

# Never run package lifecycle scripts (preinstall/install/postinstall) — the
# primary npm supply-chain attack vector. Safe here: squint-cljs is pure JS,
# and esbuild resolves its platform binary from @esbuild/* optionalDependencies
# at runtime, so it works without its postinstall script.
ignore-scripts=true

# Pin the registry explicitly so an environment variable or inherited config
# cannot silently redirect installs to a malicious mirror.
registry=https://registry.npmjs.org/

# Record exact versions (no ^ ranges) when adding new dependencies.
save-exact=true

fund=false
